<Window x:Class="CrosshairTool.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CrosshairTool 设置"
        Width="600" Height="720"
        MinWidth="520" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#1E1E1E"
        Foreground="White"
        FontFamily="Microsoft YaHei UI"
        FontSize="13">

    <Window.Resources>
        <!-- 滑块样式 -->
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- TextBox 样式 -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="26"/>
        </Style>

        <!-- ComboBox 完整深色模板（覆盖 Aero2 系统主题硬编码颜色） -->
        <ControlTemplate x:Key="DarkComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="22"/>
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="2"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"/>
                <!-- 非编辑模式：显示选中项文字 -->
                <ContentPresenter x:Name="ContentSite"
                                  Grid.Column="0"
                                  Margin="6,2,2,2"
                                  VerticalAlignment="Center"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                  IsHitTestVisible="False"/>
                <!-- 编辑模式：可输入 TextBox -->
                <TextBox x:Name="PART_EditableTextBox"
                         Grid.Column="0"
                         Margin="4,2,2,2"
                         Background="Transparent"
                         Foreground="{TemplateBinding Foreground}"
                         CaretBrush="White"
                         SelectionBrush="#007ACC"
                         BorderThickness="0"
                         Visibility="Hidden"
                         IsReadOnly="{TemplateBinding IsReadOnly}"/>
                <!-- 下拉箭头按钮 -->
                <ToggleButton x:Name="ToggleButton"
                              Grid.Column="1"
                              Background="Transparent"
                              BorderThickness="0"
                              Focusable="False"
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                          RelativeSource={RelativeSource TemplatedParent}}"
                              ClickMode="Press">
                    <Path HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M 0 0 L 4 4 L 8 0 Z" Fill="#AAAAAA"/>
                </ToggleButton>
                <!-- 下拉弹出层 -->
                <Popup x:Name="PART_Popup"
                       Placement="Bottom"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Slide">
                    <Border Background="#2D2D2D"
                            BorderBrush="#555"
                            BorderThickness="1"
                            MinWidth="{TemplateBinding ActualWidth}"
                            MaxHeight="{TemplateBinding MaxDropDownHeight}">
                        <ScrollViewer>
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsEditable" Value="True">
                    <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                    <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                </Trigger>
                <Trigger Property="IsDropDownOpen" Value="True">
                    <Setter TargetName="ToggleButton" Property="Background" Value="#505050"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template" Value="{StaticResource DarkComboBoxTemplate}"/>
        </Style>

        <!-- 下拉列表项样式 -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#007ACC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox 样式 -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 分组标题 TextBlock 样式 -->
        <Style x:Key="GroupHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>

        <!-- 标签样式 -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="80"/>
        </Style>

        <!-- 按钮样式 -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0099FF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,8,16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧配置区域 -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">

                    <!-- 样式分组 -->
                    <TextBlock Style="{StaticResource GroupHeader}" Text="● 准心样式"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="类型"/>
                        <ComboBox Grid.Column="1" x:Name="CmbStyle" SelectionChanged="OnStyleChanged">
                            <ComboBoxItem Content="十字准心 (Cross)" Tag="Cross"/>
                            <ComboBoxItem Content="十字 + 中心点 (CrossDot)" Tag="CrossDot"/>
                            <ComboBoxItem Content="圆形 (Circle)" Tag="Circle"/>
                            <ComboBoxItem Content="纯中心点 (Dot)" Tag="Dot"/>
                        </ComboBox>
                    </Grid>

                    <!-- 颜色分组 -->
                    <TextBlock Style="{StaticResource GroupHeader}" Text="● 颜色与透明度"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="准心颜色"/>
                        <TextBox Grid.Column="1" x:Name="TxtColor" TextChanged="OnColorChanged"
                                 ToolTip="输入十六进制颜色，如 #00FF00"/>
                        <Rectangle Grid.Column="2" x:Name="RectColorPreview"
                                   Width="26" Height="26" Margin="4,0,0,0"
                                   Stroke="#555" StrokeThickness="1"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="透明度"/>
                        <Slider Grid.Column="1" x:Name="SliderOpacity"
                                Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.1"
                                ValueChanged="OnOpacityChanged"/>
                        <TextBlock Grid.Column="2" x:Name="TxtOpacityVal"
                                   Foreground="#AAA" VerticalAlignment="Center"
                                   HorizontalAlignment="Right" Margin="4,0,0,0"/>
                    </Grid>

                    <!-- 轮廓 -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="轮廓颜色"/>
                        <TextBox Grid.Column="1" x:Name="TxtOutlineColor" TextChanged="OnOutlineColorChanged"/>
                        <Rectangle Grid.Column="2" x:Name="RectOutlinePreview"
                                   Width="26" Height="26" Margin="4,0,0,0"
                                   Stroke="#555" StrokeThickness="1"/>
                    </Grid>

                    <!-- 尺寸分组 -->
                    <TextBlock Style="{StaticResource GroupHeader}" Text="● 尺寸"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="准心大小"/>
                        <Slider Grid.Column="1" x:Name="SliderSize"
                                Minimum="1" Maximum="50" SmallChange="1" IsSnapToTickEnabled="True" TickFrequency="1"
                                ValueChanged="OnSizeChanged"/>
                        <TextBox Grid.Column="2" x:Name="TxtSize" Margin="4,0,0,0"
                                 TextChanged="OnSizeTextChanged"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="线条粗细"/>
                        <Slider Grid.Column="1" x:Name="SliderThickness"
                                Minimum="1" Maximum="10" SmallChange="1" IsSnapToTickEnabled="True" TickFrequency="1"
                                ValueChanged="OnThicknessChanged"/>
                        <TextBox Grid.Column="2" x:Name="TxtThickness" Margin="4,0,0,0"
                                 TextChanged="OnThicknessTextChanged"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="中心间隙"/>
                        <Slider Grid.Column="1" x:Name="SliderGap"
                                Minimum="0" Maximum="20" SmallChange="1" IsSnapToTickEnabled="True" TickFrequency="1"
                                ValueChanged="OnGapChanged"/>
                        <TextBox Grid.Column="2" x:Name="TxtGap" Margin="4,0,0,0"
                                 TextChanged="OnGapTextChanged"/>
                    </Grid>

                    <!-- 线条开关分组 -->
                    <TextBlock Style="{StaticResource GroupHeader}" Text="● 线条开关"/>
                    <WrapPanel Margin="0,0,0,6">
                        <CheckBox x:Name="ChkTopLine" Content="顶部线条" Margin="0,0,16,0"
                                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>
                        <CheckBox x:Name="ChkOutline" Content="轮廓描边"
                                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>
                    </WrapPanel>

                    <!-- 中心点分组 -->
                    <TextBlock Style="{StaticResource GroupHeader}" Text="● 中心点"/>
                    <WrapPanel Margin="0,0,0,6">
                        <CheckBox x:Name="ChkDot" Content="启用中心点" Margin="0,0,16,0"
                                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>
                    </WrapPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="点颜色"/>
                        <TextBox Grid.Column="1" x:Name="TxtDotColor" TextChanged="OnDotColorChanged"/>
                        <Rectangle Grid.Column="2" x:Name="RectDotPreview"
                                   Width="26" Height="26" Margin="4,0,0,0"
                                   Stroke="#555" StrokeThickness="1"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="点大小"/>
                        <Slider Grid.Column="1" x:Name="SliderDotSize"
                                Minimum="1" Maximum="10" SmallChange="1" IsSnapToTickEnabled="True" TickFrequency="1"
                                ValueChanged="OnDotSizeChanged"/>
                        <TextBox Grid.Column="2" x:Name="TxtDotSize" Margin="4,0,0,0"
                                 TextChanged="OnDotSizeTextChanged"/>
                    </Grid>

                    <!-- 位置偏移 -->
                    <TextBlock Style="{StaticResource GroupHeader}" Text="● 位置偏移"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="X 偏移"/>
                        <TextBox Grid.Column="1" x:Name="TxtOffsetX" TextChanged="OnOffsetChanged" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="2" Style="{StaticResource Label}" Text="Y 偏移"/>
                        <TextBox Grid.Column="3" x:Name="TxtOffsetY" TextChanged="OnOffsetChanged"/>
                    </Grid>

                    <!-- 热键 -->
                    <TextBlock Style="{StaticResource GroupHeader}" Text="● 热键"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="切换热键"/>
                        <TextBox Grid.Column="1" x:Name="TxtHotkey" IsReadOnly="True"
                                 PreviewKeyDown="OnHotkeyCapture"
                                 GotFocus="OnHotkeyBoxFocus" LostFocus="OnHotkeyBoxLostFocus"
                                 ToolTip="点击此框后按下想要的热键"/>
                    </Grid>

                    <!-- 预设管理 -->
                    <TextBlock Style="{StaticResource GroupHeader}" Text="● 预设管理"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="预设名称"/>
                        <ComboBox Grid.Column="1" x:Name="CmbPresets" IsEditable="True"
                                  SelectionChanged="OnPresetSelected"/>
                        <Button Grid.Column="2" Content="保存" Margin="4,0,0,0"
                                Click="OnSavePreset"/>
                        <Button Grid.Column="3" Content="删除" Margin="4,0,0,0"
                                Background="#8B0000" Click="OnDeletePreset"/>
                    </Grid>

                </StackPanel>

                <!-- 右侧预览区域 -->
                <StackPanel Grid.Column="1" Margin="0,0,0,0">
                    <TextBlock Style="{StaticResource GroupHeader}" Text="● 实时预览"/>
                    <Border BorderBrush="#555" BorderThickness="1" Width="200" Height="200"
                            Background="#000000" HorizontalAlignment="Left">
                        <Canvas x:Name="PreviewCanvas" Width="200" Height="200"
                                ClipToBounds="True"/>
                    </Border>
                    <TextBlock Foreground="#666" FontSize="11" Margin="0,4,0,0"
                               Text="黑色背景仅供预览" TextWrapping="Wrap"/>

                    <!-- 快速颜色选择 -->
                    <TextBlock Style="{StaticResource GroupHeader}" Text="● 快速颜色"/>
                    <WrapPanel>
                        <Button Width="28" Height="28" Margin="2" Background="#00FF00"
                                Click="OnQuickColor" Tag="#00FF00" ToolTip="#00FF00"/>
                        <Button Width="28" Height="28" Margin="2" Background="#FF0000"
                                Click="OnQuickColor" Tag="#FF0000" ToolTip="#FF0000"/>
                        <Button Width="28" Height="28" Margin="2" Background="#FFFFFF"
                                Click="OnQuickColor" Tag="#FFFFFF" ToolTip="#FFFFFF"/>
                        <Button Width="28" Height="28" Margin="2" Background="#FFFF00"
                                Click="OnQuickColor" Tag="#FFFF00" ToolTip="#FFFF00"/>
                        <Button Width="28" Height="28" Margin="2" Background="#00FFFF"
                                Click="OnQuickColor" Tag="#00FFFF" ToolTip="#00FFFF"/>
                        <Button Width="28" Height="28" Margin="2" Background="#FF8C00"
                                Click="OnQuickColor" Tag="#FF8C00" ToolTip="#FF8C00"/>
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- 底部按钮栏 -->
        <Border Grid.Row="1" BorderBrush="#333" BorderThickness="0,1,0,0"
                Background="#252526" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Grid.Column="0"
                           Foreground="#888" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="重置默认" Margin="0,0,8,0"
                        Background="#555" Click="OnResetDefault"/>
                <Button Grid.Column="2" Content="保存并关闭" Click="OnSaveAndClose"/>
            </Grid>
        </Border>
    </Grid>
</Window>
