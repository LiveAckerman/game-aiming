<Window x:Class="FPSToolbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FPS 工具箱"
        Width="760" Height="500"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="White"
        FontFamily="Microsoft YaHei UI"
        FontSize="13">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0099FF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#444"/>
                    <Setter Property="Foreground" Value="#888"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#555"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#8B0000"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- 顶部标题栏 -->
        <Border DockPanel.Dock="Top" Background="#252526" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🛡" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="FPS 工具箱" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtToolboxVersion" Text="v1.0.0" FontSize="12"
                               Foreground="#888" VerticalAlignment="Bottom" Margin="6,0,0,3"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 检查更新(手动触发) -->
                    <Button x:Name="BtnCheckUpdate" Content="🔄 检查更新" Click="OnCheckUpdateClicked"
                            Style="{StaticResource SecondaryButton}" Padding="10,4" Height="28" Margin="0,0,8,0"/>
                    <!-- 发现新版徽章 -->
                    <Border x:Name="ToolboxUpdateBadge" Visibility="Collapsed"
                            Background="#D13438" CornerRadius="3" Padding="8,4" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtNewToolboxVersion" Text="🆕 v1.1.0 可用"
                                       Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="BtnUpdateToolbox" Content="立即更新" Click="OnUpdateToolboxClicked"
                            Visibility="Collapsed" Padding="10,4" Height="28" Margin="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 底部设置栏 -->
        <Border DockPanel.Dock="Bottom" Background="#252526" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="18,10">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="ChkAutoStart" Content="开机自启" Margin="0,0,18,0"
                              Checked="OnAutoStartChanged" Unchecked="OnAutoStartChanged"/>
                    <CheckBox x:Name="ChkMinToTray" Content="关闭窗口时最小化到托盘"
                              Checked="OnMinToTrayChanged" Unchecked="OnMinToTrayChanged"/>
                </StackPanel>
                <TextBlock x:Name="TxtFooterVersion" Text="版本 v1.0.0" Foreground="#666" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 中间卡片区 -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
            <WrapPanel x:Name="CardsPanel" Orientation="Horizontal"/>
        </ScrollViewer>
    </DockPanel>
</Window>
